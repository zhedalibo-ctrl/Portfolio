---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Tag from '@/components/Tag.astro';
import { fmtDate, slugOf } from '@/lib/content';

export async function getStaticPaths() {
  const articles = await getCollection('articles', (e) => !e.data.draft || import.meta.env.DEV);
  return articles.map((article) => ({
    params: { slug: slugOf(article) },
    props: { article },
  }));
}

const { article } = Astro.props;
const { data } = article;
// 有原始 HTML 时跳过 Markdown 解析，直接注入；否则正常渲染 Markdown
const useHtml = !!data.contentHtml;
const { Content } = useHtml ? { Content: null } : await render(article);
---

<BaseLayout title={data.title} description={data.summary} narrow>
  <article>
    <!-- 文章头 -->
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <Tag text={data.platform} variant="accent" />
        <time class="text-xs text-gray-500" datetime={data.publishedAt.toISOString()}>
          {fmtDate(data.publishedAt)}
        </time>
        {data.updatedAt && (
          <span class="text-xs text-gray-500">· 更新于 {fmtDate(data.updatedAt)}</span>
        )}
      </div>

      <h1 class="text-3xl sm:text-4xl font-bold mb-4 text-foreground leading-tight tracking-tight">
        {data.title}
      </h1>

      <p class="text-lg text-gray-600 dark:text-gray-700 leading-relaxed mb-5">{data.summary}</p>

      <!-- 外链原文入口 -->
      {data.sourceUrl && (
        <a
          href={data.sourceUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 text-sm text-accent hover:underline font-medium"
        >
          前往{data.platform}原文
          <span aria-hidden="true">↗</span>
        </a>
      )}

      {data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-6 pt-6 border-t border-border">
          {data.tags.map((t) => <Tag text={t} />)}
        </div>
      )}
    </header>

    <!-- 正文：公众号原始 HTML 原样注入，保留内联样式；否则 Markdown 排版 -->
    {
      useHtml ? (
        <div class="raw-html-content max-w-none" set:html={data.contentHtml} />
      ) : (
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>
      )
    }

    <!-- 回到列表 -->
    <footer class="mt-16 pt-8 border-t border-border-soft">
      <a href="/articles" class="text-sm text-muted hover:text-accent transition-colors">
        ← 返回文章列表
      </a>
    </footer>
  </article>
</BaseLayout>
