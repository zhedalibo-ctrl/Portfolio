---
import Tag from '@/components/Tag.astro';
import { fmtDate, slugOf, type Article } from '@/lib/content';

interface Props {
  article: Article;
}
const { article } = Astro.props;
const { data } = article;
const href = `/articles/${slugOf(article)}/`;
---

<article class="card group p-5 flex flex-col">
  <div class="flex items-center gap-2 mb-3">
    <Tag text={data.platform} variant="accent" />
    <time class="text-xs text-gray-500" datetime={data.publishedAt.toISOString()}>
      {fmtDate(data.publishedAt)}
    </time>
  </div>

  <h3 class="text-lg font-semibold mb-2 text-foreground tracking-tight group-hover:text-accent transition-colors">
    <a href={href}>{data.title}</a>
  </h3>

  <p class="text-sm text-gray-600 dark:text-gray-700 leading-relaxed line-clamp-3 mb-4 flex-1">
    {data.summary}
  </p>

  <div class="flex flex-wrap gap-1.5">
    {data.tags.map((t) => <Tag text={t} />)}
  </div>
</article>
