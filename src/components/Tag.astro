---
interface Props {
  text: string;
  variant?: 'default' | 'accent' | 'muted';
}
const { text, variant = 'default' } = Astro.props;
const styles: Record<string, string> = {
  default: 'bg-gray-100 dark:bg-gray-200 text-gray-700 dark:text-gray-700 border border-border',
  accent: 'text-accent border border-accent/30 bg-accent/10',
  muted: 'bg-gray-100 dark:bg-gray-200 text-gray-500 border border-border',
};
---

<span class:list={['inline-flex items-center text-xs px-2 py-0.5 rounded-md font-medium', styles[variant]]}>
  {text}
</span>
